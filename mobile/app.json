{
  "expo": {
    "owner": "stella-ai",
    "name": "Stella",
    "slug": "stella-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "stella-mobile",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#edf3fb"
    },
    "ios": {
      "bundleIdentifier": "com.stella.mobile",
      "buildNumber": "10",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.stella.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#edf3fb"
        }
      ],
      "expo-secure-store",
      "expo-router",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Stella needs access to your photo library so you can attach images to messages."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Stella uses the camera to scan the pairing QR code shown on your computer.",
          "recordAudioAndroid": false
        }
      ],
      "expo-font",
      "expo-image",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.stella.mobile.LiveActivities",
          "groupIdentifier": "group.com.stella.mobile.liveactivities",
          "enablePushNotifications": false,
          "widgets": [
            {
              "name": "ComputerActivity",
              "displayName": "Stella Computer",
              "description": "Tracks the progress of a Stella request running on your computer.",
              "supportedFamilies": []
            }
          ]
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Stella needs access to your microphone for voice input."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "892d4162-8a4f-40e8-a0d5-b24516cb7537"
      }
    }
  }
}
