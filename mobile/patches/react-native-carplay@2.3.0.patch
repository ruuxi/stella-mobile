 #import <React/RCTConvert.h>
 #import <React/RCTRootView.h>
 
+// Stella diagnostics: mirror key CarPlay bridge steps into the same
+// user-defaults breadcrumb store the scene delegate writes
+// (StellaCarPlayDiagnostics), so on-unit failures of the JS root-template
+// takeover are visible in Console.app / the diagnostics dump.
+static void RNCPStellaLog(NSString *format, ...) {
+    va_list args;
+    va_start(args, format);
+    NSString *message = [[NSString alloc] initWithFormat:format arguments:args];
+    va_end(args);
+
+    NSLog(@"[carplay] %@", message);
+
+    NSUserDefaults *defaults = [NSUserDefaults standardUserDefaults];
+    NSArray<NSString *> *existing = [defaults stringArrayForKey:@"StellaCarPlayDiagnostics"] ?: @[];
+    NSMutableArray<NSString *> *next = [existing mutableCopy];
+    [next addObject:[NSString stringWithFormat:@"%@ %@", [NSDate date], message]];
+    while (next.count > 80) {
+        [next removeObjectAtIndex:0];
+    }
+    [defaults setObject:next forKey:@"StellaCarPlayDiagnostics"];
+}
+
 @implementation RNCarPlay
 
 @synthesize interfaceController;
